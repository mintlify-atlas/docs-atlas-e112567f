  "projectType": "saas",
  "projectName": "Courser",
  "projectDescription": "Courser is an AI-powered platform that lets professors build course-specific chatbots trained on lecture videos, enabling students to get instant, cited answers to their questions.",
  "theme": "almond",
  "primaryColor": "#fac94a",
