  "keyFeatures": [
    "AI chatbots trained on YouTube lecture videos with automatic transcript processing",
    "Cited answers with timestamped links back to the exact lecture moment",
    "Embeddable chatbot widget for integration with LMS platforms like Canvas",
    "Customizable chatbot appearance including colors, background image, and placeholder text",
    "Bring-your-own OpenAI API key per course",
    "Conversation history export as CSV for analysis",
    "Email and Google OAuth authentication",
    "Vector similarity search via Pinecone for semantically relevant context retrieval"
  ],
  "publicApiSurface": [
    "POST /auth/google",
    "POST /auth/signup-email",
    "POST /auth/login-email",
    "GET /auth/isloggedin",
    "POST /chatbot/chat",
    "POST /chatbot/create",
    "GET /chatbot/:courseId/dataset/count",
    "GET /chatbot/:courseId/dataset/export",
    "GET /course/getAllCourses",
    "GET /course/getCourse/:courseID",
    "POST /course/update",
    "GET /course/getCourseProtected/:courseID"
  ]
}
